String VolcanoSpeechService::getDefaultConfigJSON()
{
    // 返回默认配置的JSON字符串
    return R"({
        "services": {
            "volcano": {
                "apiKey": "",
                "secretKey": "",
                "region": "cn-north-1",
                "language": "zh-CN",
                "voice": "zh-CN_female_standard",
                "enablePunctuation": true,
                "timeout": 10.0
            }
