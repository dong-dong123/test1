void VolcanoSpeechService::logEvent(const String &event, const String &details) const
{
    if (logger)
    {
        String message = "VolcanoSpeechService: " + event;
        if (!details.isEmpty())
        {
            message += " - " + details;
        }
        logger->log(Logger::Level::INFO, message);
    }
}

